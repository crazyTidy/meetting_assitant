# Application Configuration
APP_NAME=Meeting Assistant
APP_VERSION=1.0.0
DEBUG=false

# ============================================================
# 数据库配置 - Database Configuration
# ============================================================
# 选择数据库类型：取消注释（删除行首的 #）其中一个即可
# Choose database type: Uncomment (remove #) one of the following

DATABASE_TYPE=sqlite
# DATABASE_TYPE=postgresql

# ------------------ SQLite 配置 (开发环境推荐) ------------------
# SQLite Configuration (Development Environment)
# 无需额外服务，开箱即用 - No additional service needed
SQLITE_DB_PATH=./meeting_assistant.db

# ------------------ PostgreSQL 配置 (生产环境推荐) ------------------
# PostgreSQL Configuration (Production Environment)
# 需要启动 PostgreSQL 服务 - Requires PostgreSQL service
# 使用方法：docker-compose --profile postgres up -d
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=meeting_assistant
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
# ============================================================

# External APIs
ZHIPU_API_KEY=your_zhipu_api_key_here
SEPARATION_API_KEY=your_separation_api_key_here
SEPARATION_API_URL=http://192.168.0.100:40901/recognize
ASR_API_KEY=
ASR_API_URL=

# Task Processing
TASK_RETRY_COUNT=3
TASK_POLLING_INTERVAL=3
